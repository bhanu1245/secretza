generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                     String                    @id @default(cuid())
  email                  String                    @unique
  name                   String?
  emailVerified          DateTime?
  passwordHash           String?
  image                  String?
  role                   String                    @default("user")
  isVerified             Boolean                   @default(false)
  isSuspended            Boolean                   @default(false)
  isPremium              Boolean                   @default(false)
  premiumExpiry          DateTime?
  provider               String                    @default("email")
  providerId             String?
  lastLoginAt            DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  accounts               Account[]
  auditLogs              AuditLog[]
  listings               Listing[]
  reviewedImages         ListingImage[]
  reviewedManualPayments ManualPaymentSubmission[] @relation("ManualPaymentReviewer")
  manualPayments         ManualPaymentSubmission[] @relation("ManualPaymentUser")
  notifications          Notification[]
  payments               Payment[]
  reviews                Review[]
  reviewReports          ReviewReport[]
  reviewCredits          ReviewCredit[]
  sessions               Session[]
}

model Category {
  id           String    @id @default(cuid())
  name         String    @unique
  slug         String    @unique
  description  String?
  icon         String?
  color        String    @default("#7C3AED")
  order        Int       @default(0)
  isActive     Boolean   @default(true)
  isFeatured   Boolean   @default(false)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  listings     Listing[]
}

model Country {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  slug         String    @unique
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  listings     Listing[]
  states       State[]
}

model State {
  id           String    @id @default(cuid())
  name         String
  slug         String
  countryId    String
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cities       City[]
  listings     Listing[]
  country      Country   @relation(fields: [countryId], references: [id])
}

model City {
  id           String    @id @default(cuid())
  name         String
  slug         String
  stateId      String
  isFeatured   Boolean   @default(false)
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  state        State     @relation(fields: [stateId], references: [id])
  listings     Listing[]
}

model Listing {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  description      String
  categorySlug     String
  countrySlug      String
  stateSlug        String
  citySlug         String
  tags             String         @default("[]")
  price            String?
  currency         String         @default("USD")
  contactEmail     String?
  contactTelegram  String?
  contactInstagram String?
  contactWebsite   String?
  contactText      String?
  images           String         @default("[]")
  status           String         @default("pending")
  isFeatured       Boolean        @default(false)
  isBoosted        Boolean        @default(false)
  featuredUntil    DateTime?
  boostUntil       DateTime?
  lastBumpedAt     DateTime?
  priorityScore    Float          @default(0)
  expiresAt        DateTime?
  riskScore        Int            @default(0)
  viewCount        Int            @default(0)
  reportCount      Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  userId           String
  categoryId       String
  countryId        String
  stateId          String
  cityId           String
  city             City           @relation(fields: [cityId], references: [id])
  state            State          @relation(fields: [stateId], references: [id])
  country          Country        @relation(fields: [countryId], references: [id])
  category         Category       @relation(fields: [categoryId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  listingImages    ListingImage[]
  payments         Payment[]
  reports          Report[]
  reviews          Review[]

  @@index([userId, status])
  @@index([categorySlug, citySlug, status])
  @@index([citySlug, status])
  @@index([status, priorityScore(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model ListingImage {
  id               String    @id @default(cuid())
  listingId        String
  url              String
  thumbnailUrl     String
  mediumUrl        String
  storageKey       String
  mimeType         String
  width            Int
  height           Int
  sizeBytes        Int
  sortOrder        Int       @default(0)
  moderationStatus String    @default("pending")
  moderationReason String?
  isFlagged        Boolean   @default(false)
  reviewedBy       String?
  reviewedAt       DateTime?
  blurHash         String?
  createdAt        DateTime  @default(now())
  reviewer         User?     @relation(fields: [reviewedBy], references: [id])
  listing          Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  listingId   String?
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending")
  method      String
  gatewayTxId String?
  couponCode  String?
  invoiceUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  listing     Listing? @relation(fields: [listingId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percentage")
  discountValue Float
  maxUses       Int
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  listingId   String
  reason      String
  description String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action, createdAt(sort: Desc)])
  @@index([entityType, entityId])
}

model ManualPaymentSubmission {
  id            String    @id @default(cuid())
  userId        String
  listingId     String?
  paymentType   String
  amount        Float
  utrNumber     String    @unique
  screenshotUrl String?
  notes         String?
  status        String    @default("pending")
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviewer      User?     @relation("ManualPaymentReviewer", fields: [reviewedBy], references: [id])
  user          User      @relation("ManualPaymentUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model SeoPage {
  id              String   @id @default(cuid())
  pageType        String
  pageSlug        String
  title           String?
  metaDescription String?
  h1              String?
  introContent    String?
  canonicalUrl    String?
  noindex         Boolean  @default(false)
  isPublished     Boolean  @default(true)
  customData      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  faqs            SeoFaq[]

  @@unique([pageType, pageSlug])
  @@index([pageType])
}

model SeoFaq {
  id        String   @id @default(cuid())
  seoPageId String
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seoPage   SeoPage  @relation(fields: [seoPageId], references: [id], onDelete: Cascade)

  @@index([seoPageId])
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String?
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Review {
  id             String    @id @default(cuid())
  listingId      String
  userId         String
  rating         Int       // 1-5 stars
  title          String?
  body           String?
  isVerified     Boolean   @default(false)
  isFeatured     Boolean   @default(false)
  isPremium      Boolean   @default(false)
  featuredUntil  DateTime?
  status         String    @default("pending") // pending | approved | rejected | flagged
  flaggedReason  String?
  moderatedBy    String?
  moderatedAt    DateTime?
  adminNote      String?
  helpfulCount   Int       @default(0)
  reportCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  listing        Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports        ReviewReport[]

  @@unique([listingId, userId]) // One review per user per listing
  @@index([listingId, status])
  @@index([userId])
  @@index([rating])
  @@index([status])
  @@index([isFeatured])
  @@index([createdAt(sort: Desc)])
}

model ReviewReport {
  id          String   @id @default(cuid())
  reviewId    String
  userId      String   // Reporter
  reason      String
  description String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId]) // One report per user per review
  @@index([reviewId])
}

model ReviewCredit {
  id          String   @id @default(cuid())
  userId      String
  credits     Int      @default(0)
  usedCredits Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model CrawlEvent {
  id           String   @id @default(cuid())
  userAgent    String
  path         String
  method       String   @default("GET")
  statusCode   Int      @default(200)
  responseTime Int      @default(0)
  isBot        Boolean  @default(false)
  botName      String?
  referer      String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([userAgent])
  @@index([path])
  @@index([createdAt])
  @@index([isBot, createdAt])
}
