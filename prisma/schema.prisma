generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Authentication (NextAuth)
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

// ============================================================================
// User
// ============================================================================

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

model User {
  id                     String                    @id @default(cuid())
  email                  String                    @unique
  name                   String?
  emailVerified          DateTime?
  passwordHash           String?
  image                  String?
  role                   UserRole                  @default(USER)
  isVerified             Boolean                   @default(false)
  isSuspended            Boolean                   @default(false)
  isPremium              Boolean                   @default(false)
  premiumExpiry          DateTime?
  sessionVersion         Int                       @default(0)
  provider               String                    @default("email")
  providerId             String?
  lastLoginAt            DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  accounts               Account[]
  auditLogs              AuditLog[]
  listings               Listing[]
  reviewedImages         ListingImage[]
  reviewedManualPayments ManualPaymentSubmission[] @relation("ManualPaymentReviewer")
  manualPayments         ManualPaymentSubmission[] @relation("ManualPaymentUser")
  notifications          Notification[]
  payments               Payment[]
  reviews                Review[]
  reviewReports          ReviewReport[]
  reviewCredits          ReviewCredit[]
  helpfulVotes           HelpfulVote[]
  sessions               Session[]
  listingReports         ListingReport[]
  fraudEvents            FraudEvent[]
  paymentAuditLogs       PaymentAuditLog[]         @relation("PaymentAuditActor")

  @@index([role, isSuspended])
  @@index([isPremium, premiumExpiry])
  @@index([createdAt(sort: Desc)])
}

// ============================================================================
// Geographic Hierarchy
// ============================================================================

model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  description   String?
  icon          String?
  color         String    @default("#7C3AED")
  order         Int       @default(0)
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  listingCount  Int       @default(0)
  parentId      String?
  seoTitle      String?
  seoDescription String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  parent        Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children      Category[] @relation("CategoryHierarchy")
  listings      Listing[] @relation("ListingCategory")
  subcategoryListings Listing[] @relation("ListingSubcategory")

  @@index([isActive, isFeatured])
  @@index([isActive, listingCount(sort: Desc)])
}

model Country {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  slug         String    @unique
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  listings     Listing[]
  states       State[]

  @@index([isActive, listingCount(sort: Desc)])
  @@index([slug])
}

model State {
  id           String    @id @default(cuid())
  name         String
  slug         String
  countryId    String
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cities       City[]
  listings     Listing[]
  country      Country   @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([slug, countryId])
  @@index([countryId, isActive])
  @@index([isActive, listingCount(sort: Desc)])
}

model City {
  id           String    @id @default(cuid())
  name         String
  slug         String
  stateId      String
  isFeatured   Boolean   @default(false)
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  state        State     @relation(fields: [stateId], references: [id], onDelete: Cascade)
  listings     Listing[]
  areas        Area[]
  districts    District[]

  @@unique([slug, stateId])
  @@index([stateId, isActive])
  @@index([isActive, listingCount(sort: Desc)])
  @@index([isFeatured, isActive])
}

model Area {
  id           String    @id @default(cuid())
  name         String
  slug         String
  cityId       String
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  city         City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  listings     Listing[]

  @@unique([slug, cityId])
  @@index([cityId, isActive])
  @@index([isActive, listingCount(sort: Desc)])
}

model District {
  id           String    @id @default(cuid())
  name         String
  slug         String
  cityId       String
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  city         City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  listings     Listing[]
  localities   Locality[]

  @@unique([slug, cityId])
  @@index([cityId, isActive])
  @@index([isActive, listingCount(sort: Desc)])
}

model Locality {
  id           String    @id @default(cuid())
  name         String
  slug         String
  districtId   String
  isActive     Boolean   @default(true)
  listingCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  district     District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  listings     Listing[]

  @@unique([slug, districtId])
  @@index([districtId, isActive])
  @@index([isActive, listingCount(sort: Desc)])
}

// ============================================================================
// Listing
// ============================================================================

model Listing {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  description      String
  categorySlug     String
  subcategorySlug  String?
  countrySlug      String
  stateSlug        String
  citySlug         String
  area             String?
  localitySlug      String?
  tags             String         @default("[]")
  services         String         @default("[]")
  price            String         // Decimal-safe: stored as string, parsed as number
  currency         String         @default("USD")
  contactEmail     String?
  whatsapp         String?
  contactTelegram  String?
  telegram         String?
  contactInstagram String?
  contactWebsite   String?
  contactText      String?
  age              Int?
  profileImage     String?
  galleryImages    String         @default("[]")
  images           String         @default("[]")
  status           String         @default("pending")
  isFeatured       Boolean        @default(false)
  isBoosted        Boolean        @default(false)
  isPremium        Boolean        @default(false)
  featuredUntil    DateTime?
  boostUntil       DateTime?
  lastBumpedAt     DateTime?
  priorityScore    Float          @default(0)
  expiresAt        DateTime?
  riskScore        Int            @default(0)
  views            Int            @default(0)
  viewCount        Int            @default(0)
  reportCount      Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  userId           String?
  categoryId       String
  subcategoryId    String?
  countryId        String
  stateId          String?
  cityId           String
  areaId           String?
  districtId       String?
  localityId       String?
  city             City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  areaRelation     Area?          @relation(fields: [areaId], references: [id], onDelete: SetNull)
  district         District?      @relation(fields: [districtId], references: [id], onDelete: Cascade)
  locality         Locality?     @relation(fields: [localityId], references: [id], onDelete: Cascade)
  state            State?          @relation(fields: [stateId], references: [id], onDelete: Cascade)
  country          Country        @relation(fields: [countryId], references: [id], onDelete: Cascade)
  category         Category       @relation("ListingCategory", fields: [categoryId], references: [id])
  subcategory      Category?      @relation("ListingSubcategory", fields: [subcategoryId], references: [id])
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingImages    ListingImage[]
  payments         Payment[]
  reports          Report[]          // Legacy (deprecated — use ListingReport)
  listingReports   ListingReport[]
  reviews          Review[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([countryId])
  @@index([stateId])
  @@index([cityId])
  @@index([areaId])
  @@index([categorySlug, citySlug, status])
  @@index([citySlug, status])
  @@index([localitySlug, status])
  @@index([status, priorityScore(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([isFeatured, featuredUntil])
  @@index([isBoosted, boostUntil])
  @@index([expiresAt])
  @@index([riskScore(sort: Desc)])
}

// ============================================================================
// Listing Images
// ============================================================================

model ListingImage {
  id               String    @id @default(cuid())
  listingId        String
  url              String
  thumbnailUrl     String
  mediumUrl        String
  storageKey       String
  mimeType         String
  width            Int
  height           Int
  sizeBytes        Int
  sortOrder        Int       @default(0)
  moderationStatus String    @default("pending")
  moderationReason String?
  isFlagged        Boolean   @default(false)
  reviewedBy       String?
  reviewedAt       DateTime?
  blurHash         String?
  createdAt        DateTime  @default(now())
  reviewer         User?     @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)
  listing          Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, moderationStatus])
  @@index([moderationStatus, createdAt(sort: Desc)])
  @@index([storageKey])
}

// ============================================================================
// Payments
// ============================================================================

model Payment {
  id          String   @id @default(cuid())
  userId      String
  listingId   String?
  // NOTE: Float is used for SQLite compatibility. In PostgreSQL migration,
  // this should be changed to Decimal @db.Decimal(12, 2).
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending")
  method      String
  gatewayTxId String?
  couponCode  String?
  invoiceUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  listing     Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs   PaymentAuditLog[]

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([listingId])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([gatewayTxId])
}

model ManualPaymentSubmission {
  id            String    @id @default(cuid())
  userId        String
  listingId     String?
  paymentType   String
  amount        Float
  utrNumber     String    @unique
  screenshotUrl String?
  notes         String?
  status        String    @default("pending")
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviewer      User?     @relation("ManualPaymentReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  user          User      @relation("ManualPaymentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percentage")
  discountValue Float
  maxUses       Int
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================================================
// Payment Settings (singleton — managed by admin)
// ============================================================================

model PaymentSettings {
  id                 String   @id @default(cuid())
  upiId              String
  whatsappNumber     String
  boostPrice         Float
  featuredPrice      Float
  premiumPrice       Float
  qrImageUrl         String?
  instructions       String?  // JSON string array
  boostTiers         String?  // JSON: [{label, amount, durationMinutes}]
  featuredTiers      String?  // JSON: [{label, amount, durationDays}]
  premiumTiers       String?  // JSON: [{label, amount, durationDays}]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ============================================================================
// Pricing Plans
// ============================================================================

model PricingPlan {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  price         Float
  currency      String   @default("INR")
  durationDays  Int
  featuredDays  Int      @default(0)
  boostDays     Int      @default(0)
  listingLimit  Int      @default(1)
  imageLimit    Int      @default(5)
  premiumBadge  Boolean  @default(false)
  priorityScore Float    @default(0)
  features      String   @default("[]")
  isActive      Boolean  @default(true)
  isPopular     Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ============================================================================
// CMS Pages
// ============================================================================

model CmsPage {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String
  excerpt         String?
  seoTitle        String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublished, slug])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// Reports (User-facing listing reports)
// ============================================================================

model ListingReport {
  id          String    @id @default(cuid())
  listingId   String
  userId      String    // Reporter
  reason      String
  description String?
  isResolved  Boolean   @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  moderatorNotes String?
  createdAt   DateTime  @default(now())
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId]) // One report per user per listing
  @@index([listingId, isResolved])
  @@index([userId])
  @@index([isResolved, createdAt(sort: Desc)])
}

// Legacy Report model (deprecated — use ListingReport instead)
model Report {
  id          String   @id @default(cuid())
  listingId   String
  reason      String
  description String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ============================================================================
// Audit Log
// ============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?  // JSON string for structured data
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
}

// ============================================================================
// Payment Audit Log — tracks every state change on a payment
// ============================================================================

model PaymentAuditLog {
  id            String   @id @default(cuid())
  paymentId     String
  userId        String?  // Actor who made the change
  action        String   // created | status_changed | amount_updated | refunded
  oldValue      String?  // JSON: previous state snapshot
  newValue      String?  // JSON: new state snapshot
  ipAddress     String?
  createdAt     DateTime @default(now())
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  actor         User?    @relation("PaymentAuditActor", fields: [userId], references: [id])

  @@index([paymentId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
}

// ============================================================================
// Fraud Detection
// ============================================================================

model FraudEvent {
  id           String   @id @default(cuid())
  userId       String?  // Null if unauthenticated
  entityType   String   // user | listing | payment | upload
  entityId     String?
  eventType    String   // rapid_signup | suspicious_payment | mass_upload | credential_stuffing | ip_blacklist | velocity_abuse
  severity     String   @default("medium") // low | medium | high | critical
  riskScore    Int      @default(0)
  details      String?  // JSON: evidence data
  ipAddress    String?
  userAgent    String?
  isResolved   Boolean  @default(false)
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([eventType, isResolved])
  @@index([severity, isResolved])
  @@index([ipAddress])
  @@index([createdAt(sort: Desc)])
}

// ============================================================================
// Virus Scan Results
// ============================================================================

model VirusScanResult {
  id           String   @id @default(cuid())
  fileId       String   // ListingImage.id or ManualPaymentSubmission.id
  fileType     String   // listing_image | manual_payment_screenshot
  fileUrl      String
  storageKey   String
  scanStatus   String   @default("pending") // pending | clean | infected | error
  scannerName  String   @default("clamav")
  scanResult   String?  // Scanner-specific result
  scannedAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([fileId, fileType])
  @@index([scanStatus])
  @@index([fileType, scanStatus])
}

// ============================================================================
// SEO
// ============================================================================

model SeoPage {
  id              String   @id @default(cuid())
  pageType        String
  pageSlug        String
  title           String?
  metaDescription String?
  h1              String?
  introContent    String?
  canonicalUrl    String?
  noindex         Boolean  @default(false)
  isPublished     Boolean  @default(true)
  customData      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  faqs            SeoFaq[]

  @@unique([pageType, pageSlug])
  @@index([pageType])
}

model SeoFaq {
  id        String   @id @default(cuid())
  seoPageId String
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seoPage   SeoPage  @relation(fields: [seoPageId], references: [id], onDelete: Cascade)

  @@index([seoPageId])
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ============================================================================
// Notifications
// ============================================================================

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String?
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, type])
}

// ============================================================================
// Reviews
// ============================================================================

model Review {
  id             String    @id @default(cuid())
  listingId      String
  userId         String
  rating         Int       // 1-5 stars
  title          String?
  body           String?
  isVerified     Boolean   @default(false)
  isFeatured     Boolean   @default(false)
  isPremium      Boolean   @default(false)
  featuredUntil  DateTime?
  status         String    @default("pending") // pending | approved | rejected | flagged
  flaggedReason  String?
  moderatedBy    String?
  moderatedAt    DateTime?
  adminNote      String?
  helpfulCount   Int       @default(0)
  reportCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  listing        Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports        ReviewReport[]
  helpfulVotes    HelpfulVote[]

  @@unique([listingId, userId]) // One review per user per listing
  @@index([listingId, status])
  @@index([userId])
  @@index([rating])
  @@index([status])
  @@index([isFeatured, featuredUntil])
  @@index([createdAt(sort: Desc)])
}

model ReviewReport {
  id          String   @id @default(cuid())
  reviewId    String
  userId      String   // Reporter
  reason      String
  description String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId]) // One report per user per review
  @@index([reviewId])
  @@index([userId])
}

model HelpfulVote {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId]) // One vote per user per review
  @@index([reviewId])
  @@index([userId])
}

model ReviewCredit {
  id          String   @id @default(cuid())
  userId      String
  credits     Int      @default(0)
  usedCredits Int      @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

// ============================================================================
// Analytics
// ============================================================================

model CrawlEvent {
  id           String   @id @default(cuid())
  userAgent    String
  path         String
  method       String   @default("GET")
  statusCode   Int      @default(200)
  responseTime Int      @default(0)
  isBot        Boolean  @default(false)
  botName      String?
  referer      String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([userAgent])
  @@index([path])
  @@index([createdAt])
  @@index([isBot, createdAt])
}
