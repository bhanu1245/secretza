generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
}

// ==========================================
// Auth.js Required Models
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// User Model
// ==========================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          String    @default("user") // user, admin, moderator
  isVerified    Boolean   @default(false)
  isSuspended   Boolean   @default(false)
  isPremium     Boolean   @default(false)
  premiumExpiry DateTime?
  provider      String    @default("email") // email, google
  providerId    String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts  Account[]
  sessions  Session[]

  // App relations
  listings      Listing[]
  payments      Payment[]
  auditLogs     AuditLog[]
  reviewedImages ListingImage[]
  manualPayments ManualPaymentSubmission[] @relation("ManualPaymentUser")
  reviewedManualPayments ManualPaymentSubmission[] @relation("ManualPaymentReviewer")
  notifications Notification[]
}

// ==========================================
// Category Model
// ==========================================
model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String?
  color       String    @default("#7C3AED")
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  listingCount Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listings    Listing[]
}

// ==========================================
// Geo Models
// ==========================================
model Country {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  slug        String    @unique
  isActive    Boolean   @default(true)
  listingCount Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  states      State[]
  listings    Listing[]
}

model State {
  id          String    @id @default(cuid())
  name        String
  slug        String
  countryId   String
  isActive    Boolean   @default(true)
  listingCount Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  country     Country   @relation(fields: [countryId], references: [id])
  cities      City[]
  listings    Listing[]
}

model City {
  id          String    @id @default(cuid())
  name        String
  slug        String
  stateId     String
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  listingCount Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  state       State     @relation(fields: [stateId], references: [id])
  listings    Listing[]
}

// ==========================================
// Listing Model
// ==========================================
model Listing {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String
  categorySlug  String
  countrySlug   String
  stateSlug     String
  citySlug      String
  tags          String    @default("[]")
  price         String?
  currency      String    @default("USD")
  contactEmail  String?
  contactTelegram String?
  contactInstagram String?
  contactWebsite String?
  contactText    String?
  images         String    @default("[]")
  status        String    @default("pending")
  isFeatured    Boolean   @default(false)
  isBoosted     Boolean   @default(false)
  featuredUntil DateTime?
  boostUntil    DateTime?
  lastBumpedAt  DateTime?
  priorityScore Float     @default(0)
  expiresAt     DateTime?
  riskScore     Int       @default(0)
  viewCount     Int       @default(0)
  reportCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  categoryId    String
  countryId     String
  stateId       String
  cityId        String

  user          User      @relation(fields: [userId], references: [id])
  category      Category  @relation(fields: [categoryId], references: [id])
  country       Country   @relation(fields: [countryId], references: [id])
  state         State     @relation(fields: [stateId], references: [id])
  city          City      @relation(fields: [cityId], references: [id])
  payments      Payment[]

  reports       Report[]
  listingImages ListingImage[]

  @@index([userId, status])
  @@index([categorySlug, citySlug, status])
  @@index([citySlug, status])
  @@index([status, priorityScore(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ==========================================
// Listing Image Model
// ==========================================
model ListingImage {
  id              String    @id @default(cuid())
  listingId       String
  url             String
  thumbnailUrl    String
  mediumUrl       String
  storageKey      String
  mimeType        String
  width           Int
  height          Int
  sizeBytes       Int
  sortOrder       Int       @default(0)
  moderationStatus String   @default("pending") // pending, approved, rejected, flagged
  moderationReason String?
  isFlagged       Boolean   @default(false)
  reviewedBy      String?
  reviewedAt      DateTime?
  blurHash        String?
  createdAt       DateTime  @default(now())

  listing         Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewer        User?     @relation(fields: [reviewedBy], references: [id])
}

// ==========================================
// Payment Model
// ==========================================
model Payment {
  id            String    @id @default(cuid())
  userId        String
  listingId     String?
  amount        Float
  currency      String    @default("USD")
  status        String    @default("pending")
  method        String
  gatewayTxId   String?
  couponCode    String?
  invoiceUrl    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  listing       Listing?  @relation(fields: [listingId], references: [id])
}

// ==========================================
// Coupon Model
// ==========================================
model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percentage")
  discountValue Float
  maxUses       Int
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// Report Model
// ==========================================
model Report {
  id            String    @id @default(cuid())
  listingId     String
  reason        String
  description   String?
  isResolved    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  listing       Listing   @relation(fields: [listingId], references: [id])
}

// ==========================================
// Audit Log Model
// ==========================================
model AuditLog {
  id            String    @id @default(cuid())
  userId        String?
  action        String
  entityType    String
  entityId      String?
  details       String?
  ipAddress     String?
  createdAt     DateTime  @default(now())

  user          User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action, createdAt(sort: Desc)])
  @@index([entityType, entityId])
}

// ==========================================
// Manual Payment Submission Model
// ==========================================
model ManualPaymentSubmission {
  id            String    @id @default(cuid())
  userId        String
  listingId     String?
  paymentType   String                          // boost, feature, premium
  amount        Float
  utrNumber     String
  screenshotUrl String?
  notes         String?
  status        String    @default("pending")    // pending, approved, rejected, proof_requested, duplicate
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation("ManualPaymentUser", fields: [userId], references: [id])
  reviewer      User?     @relation("ManualPaymentReviewer", fields: [reviewedBy], references: [id])

  @@unique([utrNumber])
  @@index([userId])
  @@index([status])
}

// ==========================================
// SEO Page Model — Custom SEO metadata per page
// ==========================================
model SeoPage {
  id            String    @id @default(cuid())
  pageType      String    // city, category, category_city, state, country, longtail
  pageSlug      String    // e.g., "mumbai", "escorts", "escorts/mumbai"
  title         String?
  metaDescription String?
  h1            String?
  introContent  String?
  canonicalUrl  String?
  noindex       Boolean   @default(false)
  isPublished   Boolean   @default(true)
  customData    String?   // JSON for any extra custom data
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  faqs          SeoFaq[]

  @@unique([pageType, pageSlug])
  @@index([pageType])
}

// ==========================================
// SEO FAQ Model — Frequently Asked Questions per page
// ==========================================
model SeoFaq {
  id            String    @id @default(cuid())
  seoPageId     String
  question      String
  answer        String
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  seoPage       SeoPage   @relation(fields: [seoPageId], references: [id], onDelete: Cascade)

  @@index([seoPageId])
}

// ==========================================
// Site Settings Model
// ==========================================
model SiteSettings {
  id            String    @id @default(cuid())
  key           String    @unique
  value         String
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// Notification Model
// ==========================================
model Notification {
  id            String    @id @default(cuid())
  userId        String
  type          String                          // payment_submitted, payment_approved, payment_rejected, payment_proof_requested
  title         String
  message       String?
  entityType    String?                         // ManualPaymentSubmission, etc.
  entityId      String?
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// Crawl Event Model — Tracks crawler visits for analytics
// ==========================================
model CrawlEvent {
  id            String    @id @default(cuid())
  userAgent     String
  path          String
  method        String    @default("GET")
  statusCode    Int       @default(200)
  responseTime  Int       @default(0)
  isBot         Boolean   @default(false)
  botName       String?
  referer       String?
  ipAddress     String?
  createdAt     DateTime  @default(now())

  @@index([userAgent])
  @@index([path])
  @@index([createdAt])
  @@index([isBot, createdAt])
}
